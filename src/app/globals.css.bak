@import "tailwindcss";

:root {
  --background: #f8f9fa;
  --foreground: #0B0F19; /* Deep Navy */
  --color-primary: #6366f1; /* Indigo 500 */
  --color-primary-hover: #4f46e5; /* Indigo 600 */
  --color-accent: #a855f7; /* Purple 500 */
  --color-accent-hover: #9333ea; /* Purple 600 */
}

@media (prefers-color-scheme: dark) {
  :root {
    --background: #0B0F19; /* Deep Indigo / Navy */
    --foreground: #f8fafc;
    --color-primary: #818cf8; /* Indigo 400 */
    --color-primary-hover: #a5b4fc; /* Indigo 300 */
    --color-accent: #c084fc; /* Purple 400 */
    --color-accent-hover: #d8b4fe; /* Purple 300 */
  }
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-brand-primary: var(--color-primary);
  --color-brand-hover: var(--color-primary-hover);
  --color-brand-accent: var(--color-accent);
  --font-sans: var(--font-outfit), sans-serif;
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  background-image: radial-gradient(ellipse at top, rgba(168, 85, 247, 0.08), transparent 40%),
                    radial-gradient(circle at bottom right, rgba(99, 102, 241, 0.05), transparent 40%);
  background-attachment: fixed;
  min-height: 100vh;
}

/* Glassmorphism utility */
.glass {
  background: rgba(11, 15, 25, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

@media (prefers-color-scheme: light) {
  .glass {
    background: rgba(255, 255, 255, 0.75);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }
}

/* Smooth micro-animations */
.hover-lift {
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;
}

.hover-lift:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px -10px rgba(168, 85, 247, 0.4);
}
